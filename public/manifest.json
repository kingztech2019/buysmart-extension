{
  "manifest_version": 3,
  "name": "BuySmart",
  "short_name": "BuySmart",
  "description": "AI-powered shopping assistant. Compare prices and get smart buying recommendations powered by SearXNG and OpenRouter.",
  "version": "1.0.0",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open BuySmart Sidebar"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "http://localhost:3000/",
    "http://localhost:8000/",
    "http://localhost:8080/"
  ],
  "web_accessible_resources": [
    {
      "resources": ["index.html", "unsupported.bundle.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
