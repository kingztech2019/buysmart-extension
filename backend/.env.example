# ── Required ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Recommended ─────────────────────────────────────────────────────────────
# Tavily — enables accurate price scraping from Amazon, Walmart, eBay etc.
# Free tier: 1,000 credits/month — sign up at https://app.tavily.com
# Without this, price extraction falls back to Deepcrawl or direct HTTP
TAVILY_API_KEY=your_tavily_api_key_here

# Deepcrawl — bypasses anti-bot protections and extracts structured data
# 100% free and open-source — get API key at https://deepcrawl.dev
# Highly recommended for better price extraction success rate
DEEPCRAWL_API_KEY=your_deepcrawl_api_key_here

# ── Optional — defaults shown ────────────────────────────────────────────────
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
SEARXNG_URL=http://searxng:8080
