{
  "manifest_version": 3,
  "name": "Buy Smart",
  "version": "1.0",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Sidebar"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "cookies"
  ],
  "host_permissions": [  
    "http://localhost:3000/"  
  ],
  
  "web_accessible_resources": [
    {
      "resources": ["index.html","unsupported.bundle.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
