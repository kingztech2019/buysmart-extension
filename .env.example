# ─────────────────────────────────────────────────────
# BuySmart — Root Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────

# ── OpenRouter (Required) ─────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── OpenRouter Model (Optional) ───────────────────────
# Free models: mistralai/mistral-7b-instruct, google/gemma-7b-it
# Paid models: anthropic/claude-haiku, google/gemini-flash-1.5
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# ── SearXNG (Optional) ────────────────────────────────
# Change this to a strong random string in production
SEARXNG_SECRET_KEY=buysmart-change-this-secret-key

# ── Tavily (Optional but Recommended) ─────────────────
# Get a free API key at https://app.tavily.com
# Free tier: 1,000 credits/month
TAVILY_API_KEY=

# ── Deepcrawl (Optional but Highly Recommended) ───────
# Get a free API key at https://deepcrawl.dev
# 100% free and open-source - bypasses anti-bot protections
DEEPCRAWL_API_KEY=
